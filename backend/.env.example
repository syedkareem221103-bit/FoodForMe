# FoodForMe - Backend Environment Variables Template
# Copy this file to '.env' and fill in your actual production values.

# Server Configuration
PORT=5001
NODE_ENV=production

# Database Connection (MongoDB Atlas connection string for production)
# Example Atlas format: mongodb+srv://<username>:<password>@cluster.mongodb.net/foodforme?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/foodforme

# JWT Security Configuration (Use a strong random 32-character string in production)
JWT_SECRET=super_secret_foodforme_key_change_me_in_production_987654321

# CORS Hardening (Comma-separated allowed client frontend URLs in production)
# Example: https://foodforme.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=https://foodforme.vercel.app,http://localhost:5173

# Database Seeding Force Flag (Optional: Set to 'true' only if you explicitly want to override the production seed safety block)
FORCE_SEED=false
