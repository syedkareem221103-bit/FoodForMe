# FoodForMe - Frontend Client Environment Variables
# Copy this file to '.env' or add these parameters in your Vercel project configuration dashboard.

# Production API Base URL (Point to your deployed Render or backend service URL)
# NOTE: In Vite, environment variables MUST begin with 'VITE_' prefix to be compiled and accessible.
VITE_API_BASE_URL=https://foodforme-backend.onrender.com/api
